{
  "name": "@tscircuit/fake-ul-kicad-proxy",
  "version": "0.0.1",
  "description": "Fake UL KiCad Proxy for testing",
  "module": "lib/index.ts",
  "type": "module",
  "files": ["dist", "lib", "routes", "winterspec.config.ts"],
  "main": "lib/index.ts",
  "types": "lib/types.ts",
  "exports": {
    ".": "./lib/index.ts",
    "./dist/bundle.js": {
      "types": "./lib/bundle.d.ts",
      "import": "./dist/bundle.js"
    },
    "./types": "./lib/types.ts"
  },
  "scripts": {
    "start": "winterspec dev",
    "dev": "winterspec dev",
    "build": "winterspec bundle -o dist/bundle.js",
    "prepare": "bun run build",
    "test": "bun test",
    "format": "biome format --write .",
    "format:check": "bun x biome format .",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.2",
    "@tscircuit/circuit-json-util": "^0.0.94",
    "@types/bun": "latest",
    "bun-match-svg": "^0.0.15",
    "circuit-json": "^0.0.433",
    "circuit-json-to-connectivity-map": "^0.0.23",
    "circuit-to-svg": "^0.0.354",
    "kicad-to-circuit-json": "^0.0.96",
    "kicadts": "^0.0.44"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ky": "^2.0.2",
    "winterspec": "^0.0.114",
    "zod": "^3.23.8",
    "zustand": "^5.0.13",
    "zustand-hoist": "^2.0.1"
  }
}
